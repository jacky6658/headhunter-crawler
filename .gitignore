# ═══════════════════════════════════════════
# HeadHunter Crawler - Git Ignore
# ═══════════════════════════════════════════

# ── 執行資料（每台電腦不同，自動產生） ──
data/
logs/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
venv/
.venv/
env/
.env

# ── 系統 ──
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── IDE ──
.vscode/
.idea/
*.iml

# ── 測試 ──
.pytest_cache/
.coverage
htmlcov/

# ── Claude ──
.claude/

# ── 機密檔案（公開倉庫，不納入版控） ──
credentials.json
*.pem
*.key
